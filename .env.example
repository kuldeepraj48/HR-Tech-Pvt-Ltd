# Application (required)
APP_NAME="Sembark URL Shortener"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database — use either SQLite or MySQL
DB_CONNECTION=sqlite
DB_DATABASE="C:/absolute/path/to/your/project/database/database.sqlite"

# If using MySQL instead, comment SQLite above and use:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=url_shortener
# DB_USERNAME=root
# DB_PASSWORD=

# Cache & session (defaults; no need to change for basic use)
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
